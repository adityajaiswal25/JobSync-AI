    {
      "parameters": {
        "jsCode": "// Get Gemini raw output\nconst raw = $input.first().json.text || '';\n\n// Strip markdown code fences if Gemini wrapped output\nlet cleaned = raw.trim();\ncleaned = cleaned.replace(/^```latex\\s*/i, '');\ncleaned = cleaned.replace(/^```\\s*/i, '');\ncleaned = cleaned.replace(/\\s*```$/i, '');\ncleaned = cleaned.trim();\n\n// Validate it looks like LaTeX\nif (!cleaned.includes('\\\\documentclass') || !cleaned.includes('\\\\end{document}')) {\n  throw new Error('Gemini output does not look like valid LaTeX. Raw output: ' + raw.substring(0, 200));\n}\n\n// Convert LaTeX string to binary buffer (UTF-8) for file upload\nconst buffer = Buffer.from(cleaned, 'utf-8');\n\nreturn [\n  {\n     \n  binary: {\n      latexFile: {\n        data: buffer.toString('base64'),\n        mimeType: 'application/x-latex',\n        fileName: 'resume.tex',\n        fileExtension: 'tex'\n      }\n    }\n  }\n];"
      },
