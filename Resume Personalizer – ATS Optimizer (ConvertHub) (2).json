        "jsCode": "const body = $input.first().json.body;\nconst binary = $input.first().binary;\n\nconst email = body.email || '';\nconst jd = body.jd || '';\n\n// Binary mein resume check karo\nconst isNewUser = !!(binary && Object.keys(binary).length > 0);\n\nif (!email) throw new Error('Email missing');\nif (!jd) throw new Error('Job Description missing');\n\nreturn [\n  {\n    json: {\n      email,\n      jd,\n      isNewUser\n    }\n  }\n];"
